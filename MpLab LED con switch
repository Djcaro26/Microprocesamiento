LIST P=16F877A
        #include <P16F877A.INC>

;==============================
; CONFIGURACIÓN
;==============================
        __CONFIG _CP_OFF & _WDT_OFF & _PWRTE_ON & _HS_OSC

        ORG 0x00
        GOTO INIT

;==============================
; INICIALIZACIÓN
;==============================
INIT
        BSF STATUS, RP0          ; Banco 1

        MOVLW b'00000010'        ; RB1 entrada, resto salida
        MOVWF TRISB

        BCF STATUS, RP0          ; Banco 0

        CLRF PORTB               ; Apagar todo

;==============================
; PROGRAMA PRINCIPAL
;==============================
MAIN
        BTFSC PORTB,1            ; ¿RB1 = 1?
        BSF PORTB,0              ; Sí ? LED ON

        BTFSS PORTB,1            ; ¿RB1 = 0?
        BCF PORTB,0              ; Sí ? LED OFF

        GOTO MAIN

        END
